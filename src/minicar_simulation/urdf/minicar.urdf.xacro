<?xml version="1.0"?>
<robot name="minicar" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================================================================== -->
  <!-- Colors and Materials -->
  <!-- ==================================================================== -->
  <material name="cyan">
    <color rgba="0.0 0.8 0.8 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="silver">
    <color rgba="0.8 0.8 0.8 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <!-- ==================================================================== -->
  <!-- Inertial Macros -->
  <!-- ==================================================================== -->
  <!-- Solid Box Inertia -->
  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(1.0/12.0) * mass * (y*y + z*z)}" ixy="0.0" ixz="0.0"
               iyy="${(1.0/12.0) * mass * (x*x + z*z)}" iyz="0.0"
               izz="${(1.0/12.0) * mass * (x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid Cylinder Inertia -->
  <xacro:macro name="cylinder_inertial" params="mass r h">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(1.0/12.0) * mass * (3*r*r + h*h)}" ixy="0.0" ixz="0.0"
               iyy="${(1.0/12.0) * mass * (3*r*r + h*h)}" iyz="0.0"
               izz="${0.5 * mass * r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- Solid Sphere Inertia -->
  <xacro:macro name="sphere_inertial" params="mass r">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${(2.0/5.0) * mass * r*r}" ixy="0.0" ixz="0.0"
               iyy="${(2.0/5.0) * mass * r*r}" iyz="0.0"
               izz="${(2.0/5.0) * mass * r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- ==================================================================== -->
  <!-- Links and Joints -->
  <!-- ==================================================================== -->

  <!-- Base Footprint (Virtual link representing ground projection) -->
  <link name="base_footprint"/>

  <!-- Base Link (Chassis) -->
  <link name="base_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <material name="cyan"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="2.0" x="0.4" y="0.3" z="0.1"/>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- The chassis bottom is 0.03m above ground. Axis center is at z = 0.08m -->
    <origin xyz="0.0 0.0 0.08" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- Rear Left Wheel -->
  <link name="left_wheel">
    <visual>
      <!-- Cylinders are along Z by default, so we rotate it to align with axle (along Y) -->
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.5" r="0.08" h="0.05"/>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Positioned at the rear-left relative to chassis center -->
    <origin xyz="-0.1 0.175 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- Rear Right Wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.5" r="0.08" h="0.05"/>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- Positioned at the rear-right relative to chassis center -->
    <origin xyz="-0.1 -0.175 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- Front Left Steering Link & Joint -->
  <link name="front_left_steering">
    <xacro:box_inertial mass="0.05" x="0.02" y="0.02" z="0.02"/>
  </link>

  <joint name="front_left_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_left_steering"/>
    <origin xyz="0.12 0.175 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limit lower="-1.05" upper="1.05" effort="10.0" velocity="1.0"/>
  </joint>

  <!-- Front Left Wheel Link & Joint -->
  <link name="front_left_wheel">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.5" r="0.08" h="0.05"/>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="front_left_steering"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- Front Right Steering Link & Joint -->
  <link name="front_right_steering">
    <xacro:box_inertial mass="0.05" x="0.02" y="0.02" z="0.02"/>
  </link>

  <joint name="front_right_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_right_steering"/>
    <origin xyz="0.12 -0.175 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 0.0 1.0"/>
    <limit lower="-1.05" upper="1.05" effort="10.0" velocity="1.0"/>
  </joint>

  <!-- Front Right Wheel Link & Joint -->
  <link name="front_right_wheel">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="${pi/2} 0.0 0.0"/>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertial mass="0.5" r="0.08" h="0.05"/>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="front_right_steering"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- Camera Link -->
  <link name="camera_link">
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="0.05" x="0.03" y="0.03" z="0.03"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Mounted at the absolute front of the chassis, top edge -->
    <origin xyz="0.2 0.0 0.05" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- Camera Optical Link (Standard camera frame for ROS/CV image processing) -->
  <link name="camera_optical_link"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
    <!-- Rotated from standard robot body coordinate frame (X-forward) to optical frame (Z-forward) -->
    <origin xyz="0.0 0.0 0.0" rpy="${-pi/2} 0.0 ${-pi/2}"/>
  </joint>

  <!-- ==================================================================== -->
  <!-- Gazebo Specific Configurations & Plugins -->
  <!-- ==================================================================== -->

  <!-- Materials for Gazebo Sim Rendering -->
  <gazebo reference="base_link">
    <visual>
      <material>
        <ambient>0.0 0.8 0.8 1.0</ambient>
        <diffuse>0.0 0.8 0.8 1.0</diffuse>
        <specular>0.5 0.5 0.5 1.0</specular>
      </material>
    </visual>
  </gazebo>

  <gazebo reference="left_wheel">
    <visual>
      <material>
        <ambient>0.15 0.15 0.15 1.0</ambient>
        <diffuse>0.15 0.15 0.15 1.0</diffuse>
        <specular>0.2 0.2 0.2 1.0</specular>
      </material>
    </visual>
    <mu1>10.0</mu1>
    <mu2>10.0</mu2>
  </gazebo>

  <gazebo reference="right_wheel">
    <visual>
      <material>
        <ambient>0.15 0.15 0.15 1.0</ambient>
        <diffuse>0.15 0.15 0.15 1.0</diffuse>
        <specular>0.2 0.2 0.2 1.0</specular>
      </material>
    </visual>
    <mu1>10.0</mu1>
    <mu2>10.0</mu2>
  </gazebo>

  <!-- Front Left and Right Wheels Gazebo References -->
  <gazebo reference="front_left_wheel">
    <visual>
      <material>
        <ambient>0.15 0.15 0.15 1.0</ambient>
        <diffuse>0.15 0.15 0.15 1.0</diffuse>
        <specular>0.2 0.2 0.2 1.0</specular>
      </material>
    </visual>
    <mu1>10.0</mu1>
    <mu2>10.0</mu2>
  </gazebo>

  <gazebo reference="front_right_wheel">
    <visual>
      <material>
        <ambient>0.15 0.15 0.15 1.0</ambient>
        <diffuse>0.15 0.15 0.15 1.0</diffuse>
        <specular>0.2 0.2 0.2 1.0</specular>
      </material>
    </visual>
    <mu1>10.0</mu1>
    <mu2>10.0</mu2>
  </gazebo>

  <gazebo reference="camera_link">
    <visual>
      <material>
        <ambient>1.0 0.5 0.0 1.0</ambient>
        <diffuse>1.0 0.5 0.0 1.0</diffuse>
        <specular>0.5 0.5 0.5 1.0</specular>
      </material>
    </visual>
  </gazebo>

  <!-- Front Monocular Camera Sensor -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <camera>
        <horizontal_fov>2.094</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <!-- Published directly to Gazebo Transport topic -->
      <topic>/camera/image_raw</topic>
    </sensor>
  </gazebo>

  <!-- Ackermann Steering & Joint State Plugins -->
  <gazebo>
    <plugin
      filename="ignition-gazebo-ackermann-steering-system"
      name="ignition::gazebo::systems::AckermannSteering">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <left_steering_joint>front_left_steering_joint</left_steering_joint>
      <right_steering_joint>front_right_steering_joint</right_steering_joint>
      
      <!-- Kinematics -->
      <wheel_separation>0.35</wheel_separation>
      <kingpin_width>0.35</kingpin_width>
      <wheel_base>0.22</wheel_base>
      <wheel_radius>0.08</wheel_radius>
      <steering_limit>1.05</steering_limit>
      
      <!-- Limits and configurations -->
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_acceleration>10.0</max_linear_acceleration>
      <min_linear_acceleration>-10.0</min_linear_acceleration>
      <max_angular_acceleration>15.0</max_angular_acceleration>
      <min_angular_acceleration>-15.0</min_angular_acceleration>
      
      <!-- Topic names -->
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      
      <!-- Frame IDs -->
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>

    <!-- Joint state publisher for wheel positions in ROS2 -->
    <plugin
      filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
      <joint_name>front_left_steering_joint</joint_name>
      <joint_name>front_right_steering_joint</joint_name>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
