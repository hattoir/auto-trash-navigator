<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" xmlns:gz="http://gazebosim.org/schema">

  <!-- Macro for a single omni wheel -->
  <xacro:macro name="omni_wheel" params="prefix x_reflect y_reflect fdir">
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${x_reflect * 0.15} ${y_reflect * 0.18} -0.05" rpy="0 0 ${(1 - y_reflect) * pi / 2}"/>
      <axis xyz="0 ${y_reflect} 0"/>
    </joint>

    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.05" length="0.04"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="${(1/12) * 0.2 * (3 * 0.05 * 0.05 + 0.04 * 0.04)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.2 * (3 * 0.05 * 0.05 + 0.04 * 0.04)}" iyz="0.0"
                 izz="${0.5 * 0.2 * 0.05 * 0.05}"/>
      </inertial>
    </link>

    <gazebo reference="${prefix}_wheel_link">
      <collision name="${prefix}_wheel_link_collision">
        <surface>
          <friction>
            <ode>
              <mu>100.0</mu>
              <mu2>0.0</mu2>
              <fdir1 gz:expressed_in="base_footprint">${fdir}</fdir1>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e7</kp>
              <kd>1.0</kd>
            </ode>
          </contact>
        </surface>
      </collision>
    </gazebo>
  </xacro:macro>

  <!-- Macro to add 4 omni wheels -->
  <xacro:macro name="base_omni_4wheel">
    <xacro:omni_wheel prefix="front_left" x_reflect="1" y_reflect="1" fdir="1 -1 0"/>
    <xacro:omni_wheel prefix="front_right" x_reflect="1" y_reflect="-1" fdir="1 1 0"/>
    <xacro:omni_wheel prefix="rear_left" x_reflect="-1" y_reflect="1" fdir="1 1 0"/>
    <xacro:omni_wheel prefix="rear_right" x_reflect="-1" y_reflect="-1" fdir="1 -1 0"/>

    <!-- Mecanum Drive Plugin for Gazebo Sim -->
    <gazebo>
      <plugin
        filename="gz-sim-mecanum-drive-system"
        name="gz::sim::systems::MecanumDrive">
        <front_left_joint>front_left_wheel_joint</front_left_joint>
        <front_right_joint>front_right_wheel_joint</front_right_joint>
        <back_left_joint>rear_left_wheel_joint</back_left_joint>
        <back_right_joint>rear_right_wheel_joint</back_right_joint>
        <wheel_separation>0.36</wheel_separation>
        <wheelbase>0.30</wheelbase>
        <wheel_radius>0.05</wheel_radius>
        <topic>/cmd_vel</topic>
        <odom_topic>/odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>base_footprint</child_frame_id>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>false</publish_odom_tf>
        <odom_publish_frequency>50</odom_publish_frequency>
      </plugin>
    </gazebo>
  </xacro:macro>

</robot>
