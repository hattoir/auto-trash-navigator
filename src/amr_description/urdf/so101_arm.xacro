<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="so101_arm">
    <!-- Joint 1 -->
    <joint name="joint1" type="revolute">
      <parent link="arm_base_link"/>
      <child link="link1"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.0" upper="2.0" effort="10.0" velocity="2.0"/>
    </joint>

    <!-- Link 1 -->
    <link name="link1">
      <visual>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.03" length="0.05"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.03" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.025" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="${(1/12) * 0.2 * (3*0.03*0.03 + 0.05*0.05)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.2 * (3*0.03*0.03 + 0.05*0.05)}" iyz="0.0"
                 izz="${0.5 * 0.2 * 0.03 * 0.03}"/>
      </inertial>
    </link>

    <!-- Joint 2 -->
    <joint name="joint2" type="revolute">
      <parent link="link1"/>
      <child link="link2"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.0" upper="2.0" effort="10.0" velocity="2.0"/>
    </joint>

    <!-- Link 2 -->
    <link name="link2">
      <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.04 0.15"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.04 0.15"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <mass value="0.4"/>
        <inertia ixx="${(1/12) * 0.4 * (0.04*0.04 + 0.15*0.15)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.4 * (0.04*0.04 + 0.15*0.15)}" iyz="0.0"
                 izz="${(1/12) * 0.4 * (0.04*0.04 + 0.04*0.04)}"/>
      </inertial>
    </link>

    <!-- Joint 3 -->
    <joint name="joint3" type="revolute">
      <parent link="link2"/>
      <child link="link3"/>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.0" upper="2.0" effort="10.0" velocity="2.0"/>
    </joint>

    <!-- Link 3 -->
    <link name="link3">
      <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.03 0.15"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.03 0.15"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <mass value="0.3"/>
        <inertia ixx="${(1/12) * 0.3 * (0.03*0.03 + 0.15*0.15)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.3 * (0.03*0.03 + 0.15*0.15)}" iyz="0.0"
                 izz="${(1/12) * 0.3 * (0.03*0.03 + 0.03*0.03)}"/>
      </inertial>
    </link>

    <!-- Joint 4 -->
    <joint name="joint4" type="revolute">
      <parent link="link3"/>
      <child link="link4"/>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.0" upper="2.0" effort="10.0" velocity="2.0"/>
    </joint>

    <!-- Link 4 -->
    <link name="link4">
      <visual>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.04"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.04"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <mass value="0.15"/>
        <inertia ixx="${(1/12) * 0.15 * (3*0.02*0.02 + 0.04*0.04)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.15 * (3*0.02*0.02 + 0.04*0.04)}" iyz="0.0"
                 izz="${0.5 * 0.15 * 0.02 * 0.02}"/>
      </inertial>
    </link>

    <!-- Joint 5 -->
    <joint name="joint5" type="revolute">
      <parent link="link4"/>
      <child link="link5"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.0" upper="2.0" effort="10.0" velocity="2.0"/>
    </joint>

    <!-- Link 5 -->
    <link name="link5">
      <visual>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.04 0.04"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.04 0.04"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <mass value="0.15"/>
        <inertia ixx="${(1/12) * 0.15 * (0.04*0.04 + 0.04*0.04)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.15 * (0.03*0.03 + 0.04*0.04)}" iyz="0.0"
                 izz="${(1/12) * 0.15 * (0.03*0.03 + 0.04*0.04)}"/>
      </inertial>
    </link>

    <!-- Joint 6 -->
    <joint name="joint6" type="revolute">
      <parent link="link5"/>
      <child link="link6"/>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.0" upper="2.0" effort="10.0" velocity="2.0"/>
    </joint>

    <!-- Link 6 -->
    <link name="link6">
      <visual>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.02"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.02" length="0.02"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <mass value="0.15"/>
        <inertia ixx="${(1/12) * 0.15 * (3*0.02*0.02 + 0.02*0.02)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.15 * (3*0.02*0.02 + 0.02*0.02)}" iyz="0.0"
                 izz="${0.5 * 0.15 * 0.02 * 0.02}"/>
      </inertial>
    </link>

    <!-- Wrist Camera Joint -->
    <joint name="wrist_camera_joint" type="fixed">
      <parent link="link6"/>
      <child link="wrist_camera_link"/>
      <origin xyz="0 0.02 0.02" rpy="0 0 0"/>
    </joint>

    <!-- Wrist Camera Link -->
    <link name="wrist_camera_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.02 0.01"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.02 0.01"/>
        </geometry>
      </collision>
    </link>

    <!-- Self collision settings for arm links -->
    <gazebo reference="link1">
      <self_collision>true</self_collision>
    </gazebo>
    <gazebo reference="link2">
      <self_collision>true</self_collision>
    </gazebo>
    <gazebo reference="link3">
      <self_collision>true</self_collision>
    </gazebo>
  </xacro:macro>

</robot>
