<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="so101_gripper">
    <!-- Gripper Base Joint -->
    <joint name="gripper_base_joint" type="fixed">
      <parent link="link6"/>
      <child link="gripper_base_link"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </joint>

    <!-- Gripper Base Link -->
    <link name="gripper_base_link">
      <visual>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.06 0.03"/>
        </geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.06 0.03"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <mass value="0.3"/>
        <inertia ixx="${(1/12) * 0.3 * (0.06*0.06 + 0.03*0.03)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.3 * (0.04*0.04 + 0.03*0.03)}" iyz="0.0"
                 izz="${(1/12) * 0.3 * (0.04*0.04 + 0.06*0.06)}"/>
      </inertial>
    </link>

    <!-- Left Finger Joint -->
    <joint name="left_finger_joint" type="prismatic">
      <parent link="gripper_base_link"/>
      <child link="left_finger_link"/>
      <origin xyz="0 0.02 0.025" rpy="0 0 0"/>
      <axis xyz="0 -1 0"/>
      <limit lower="0.0" upper="0.015" effort="10.0" velocity="0.1"/>
    </joint>

    <!-- Left Finger Link -->
    <link name="left_finger_link">
      <visual>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.01 0.04"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.01 0.04"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="${(1/12) * 0.05 * (0.01*0.01 + 0.04*0.04)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.05 * (0.03*0.03 + 0.04*0.04)}" iyz="0.0"
                 izz="${(1/12) * 0.05 * (0.03*0.03 + 0.01*0.01)}"/>
      </inertial>
    </link>

    <!-- Right Finger Joint -->
    <joint name="right_finger_joint" type="prismatic">
      <parent link="gripper_base_link"/>
      <child link="right_finger_link"/>
      <origin xyz="0 -0.02 0.025" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.015" effort="10.0" velocity="0.1"/>
    </joint>

    <!-- Right Finger Link -->
    <link name="right_finger_link">
      <visual>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.01 0.04"/>
        </geometry>
        <material name="silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <geometry>
          <box size="0.03 0.01 0.04"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.02" rpy="0 0 0"/>
        <mass value="0.05"/>
        <inertia ixx="${(1/12) * 0.05 * (0.01*0.01 + 0.04*0.04)}" ixy="0.0" ixz="0.0"
                 iyy="${(1/12) * 0.05 * (0.03*0.03 + 0.04*0.04)}" iyz="0.0"
                 izz="${(1/12) * 0.05 * (0.03*0.03 + 0.01*0.01)}"/>
      </inertial>
    </link>

    <!-- Self collision settings for gripper -->
    <gazebo reference="gripper_base_link">
      <self_collision>true</self_collision>
    </gazebo>
  </xacro:macro>

</robot>
